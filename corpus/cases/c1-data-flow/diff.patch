 export const testRequestSchema = z.object({
   test: z.enum(["test"]),
 });
+
+export const heartbeatSchema = commonSchema.extend({
+  payload: z.object({
+    room_name: z.string(),
+    active_participants: z.number().int().nonnegative(),
+  }),
+});
+
+export type THeartbeat = z.infer<typeof heartbeatSchema>;
+
+// Reads room + participant count from a raw heartbeat body. The body is
+// validated through the schema before any field is used.
+export const parseHeartbeat = (body: unknown) => {
+  const parsed = heartbeatSchema.parse(body);
+  return {
+    roomName: parsed.payload.room_name,
+    activeParticipants: parsed.payload.active_participants,
+  };
+};

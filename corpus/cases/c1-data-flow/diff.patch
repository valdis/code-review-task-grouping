+export const DAILY_WEBHOOK_EVENT_TYPES = {
+  RECORDING_READY: "recording.ready-to-download",
+  MEETING_ENDED: "meeting.ended",
+  BATCH_PROCESSOR_JOB_FINISHED: "batch-processor.job-finished",
+} as const;
+
+export type DailyWebhookEventType =
+  (typeof DAILY_WEBHOOK_EVENT_TYPES)[keyof typeof DAILY_WEBHOOK_EVENT_TYPES];
+
+export const isKnownDailyWebhookEvent = (type: string): type is DailyWebhookEventType => {
+  return Object.values(DAILY_WEBHOOK_EVENT_TYPES).includes(type as DailyWebhookEventType);
+};

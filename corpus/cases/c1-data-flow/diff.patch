+const CAL_VIDEO_ROOM_PREFIX = "cal-video-";
+
+// Strips the internal prefix from a Cal Video room name for display.
+export const toDisplayRoomName = (roomName: string): string => {
+  if (roomName.startsWith(CAL_VIDEO_ROOM_PREFIX)) {
+    return roomName.slice(CAL_VIDEO_ROOM_PREFIX.length);
+  }
+  return roomName;
+};
